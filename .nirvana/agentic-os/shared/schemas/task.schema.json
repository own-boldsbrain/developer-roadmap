{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nirvana.local/schemas/task.schema.json",
  "title": "Task",
  "schemaVersion": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "taskId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "claimed",
        "completed",
        "failed"
      ]
    }
  },
  "required": [
    "taskId",
    "description",
    "status"
  ]
}