{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "title":  "Obsidian Vault Knowledge File",
    "type":  "object",
    "properties":  {
                       "file_path":  {
                                         "type":  "string"
                                     },
                       "type":  {
                                    "type":  "string",
                                    "enum":  [
                                                 "markdown",
                                                 "base",
                                                 "canvas",
                                                 "asset"
                                             ]
                                },
                       "frontmatter":  {
                                           "type":  "object",
                                           "additionalProperties":  true
                                       },
                       "tags":  {
                                    "type":  "array",
                                    "items":  {
                                                  "type":  "string"
                                              }
                                },
                       "links":  {
                                     "type":  "array",
                                     "items":  {
                                                   "type":  "object",
                                                   "properties":  {
                                                                      "target":  {
                                                                                     "type":  "string"
                                                                                 },
                                                                      "resolved":  {
                                                                                       "type":  "boolean"
                                                                                   }
                                                                  }
                                               }
                                 }
                   },
    "required":  [
                     "file_path",
                     "type"
                 ],
    "$id":  "https://nirvana.local/schemas/vault-knowledge.schema.json",
    "schemaVersion":  "1.0.0",
    "additionalProperties":  false
}
