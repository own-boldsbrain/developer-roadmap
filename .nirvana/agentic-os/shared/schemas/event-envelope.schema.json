{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nirvana.local/schemas/event-envelope.schema.json",
  "title": "Event Envelope",
  "schemaVersion": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "eventType": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  },
  "required": [
    "eventId",
    "timestamp",
    "eventType",
    "source",
    "payload"
  ]
}