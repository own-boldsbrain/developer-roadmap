  "title": "RBAC Policy",
  "schemaVersion": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "policyId": {
      "type": "string"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
