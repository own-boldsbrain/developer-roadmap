{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Superpowers Specification",
  "type": "object",
  "properties": {
    "spec_id": { "type": "string" },
    "objective": { "type": "string" },
    "problem_statement": { "type": "string" },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "statement": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": ["statement", "confidence"]
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewing", "approved", "rejected"]
    }
  },
  "required": ["spec_id", "objective", "problem_statement", "acceptance_criteria", "status"]
}
