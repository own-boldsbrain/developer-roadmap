{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nirvana.local/schemas/policy-decision.schema.json",
  "title": "Policy Decision",
  "schemaVersion": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "decisionId": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "DENY",
        "REQUIRE_APPROVAL"
      ]
    },
    "reason": {
      "type": "string"
    }
  },
  "required": [
    "decisionId",
    "decision",
    "reason"
  ]
}